{
  "manifest_version": 3,
  "name": "Firefox Mission Control",
  "version": "1.0.0",
  "description": "A keyboard-first visual overview of open tabs in the current Firefox window.",
  "permissions": [
    "tabs"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "action": {
    "default_title": "Open Mission Control"
  },
  "commands": {
    "open-mission-control": {
      "suggested_key": {
        "default": "Ctrl+Shift+Space",
        "mac": "Command+Shift+Space"
      },
      "description": "Open the Mission Control tab overview"
    }
  },
  "icons": {
    "16": "icons/icon-16.svg",
    "32": "icons/icon-32.svg",
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "firefox-mission-control@example.local"
    }
  }
}
